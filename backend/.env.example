# Example environment variables for backend (do NOT commit secrets)
NODE_ENV=development
PORT=5000
# For local compose use: mongodb://mongo:27017/finalyearproject
# For Atlas use your connection string (do NOT commit it to the repo)
MONGODB_URI=mongodb://localhost:27017/finalyearproject
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRE=7d
FRONTEND_URL=http://localhost:5173

# File upload configuration
MAX_FILE_SIZE=5000000
FILE_UPLOAD_PATH=./uploads

# Frontend API (used for local dev)
REACT_APP_API_URL=http://localhost:5000/api

# Email configuration (optional)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@example.com
EMAIL_APP_PASSWORD=your-email-app-password
EMAIL_TIMEOUT_MS=20000
EMAIL_SECURE=false
